<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0                              http://maven.apache.org/xsd/maven-4.0.0.xsd">

  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>se.fk.maven</groupId>
    <artifactId>fk-maven-quarkus-parent</artifactId>
    <version>1.12.0</version>
  </parent>
  <groupId>se.fk.rimfrost.framework.regel.manuell</groupId>
  <artifactId>rimfrost-framework-regel-manuell</artifactId>
  <version>1.0.0-SNAPSHOT</version>
  <packaging>jar</packaging>

  <name>Rimfrost Framework regel manuell</name>

  <distributionManagement>
    <repository>
      <id>github--Forsakringskassan--repository</id>
      <url>https://maven.pkg.github.com/Forsakringskassan/repository</url>
    </repository>
  </distributionManagement>

  <properties>
    <violations.maxViolations>0</violations.maxViolations>
    <quarkus.platform.group-id>io.quarkus.platform</quarkus.platform.group-id>
    <quarkus.build.skip>true</quarkus.build.skip>
  </properties>

  <dependencies>
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-arc</artifactId>
    </dependency>
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-junit5-mockito</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.immutables</groupId>
      <artifactId>value</artifactId>
      <version>2.11.6</version>
    </dependency>
    <dependency>
      <groupId>org.yaml</groupId>
      <artifactId>snakeyaml</artifactId>
      <version>2.5</version>
    </dependency>
    <dependency>
      <groupId>se.fk.github.jaxrsclientfactory</groupId>
      <artifactId>jaxrs-client-factory</artifactId>
      <version>1.3.0</version>
    </dependency>
    <dependency>
      <groupId>se.fk.github.logging</groupId>
      <artifactId>fk-logging</artifactId>
      <version>0.3.0</version>
    </dependency>
    <dependency>
      <groupId>se.fk.rimfrost.framework.regel.manuell</groupId>
      <artifactId>rimfrost-framework-regel-manuell-openapi-jaxrs-spec</artifactId>
      <version>1.0.1</version>
    </dependency>
    <dependency>
      <groupId>se.fk.rimfrost.framework.oul</groupId>
      <artifactId>rimfrost-framework-oul</artifactId>
      <version>1.0.0</version>
    </dependency>
    <dependency>
      <groupId>se.fk.rimfrost.framework.regel</groupId>
      <artifactId>rimfrost-framework-regel</artifactId>
      <version>1.0.0</version>
    </dependency>
    <dependency>
      <groupId>se.fk.rimfrost.framework.regel</groupId>
      <artifactId>rimfrost-framework-regel</artifactId>
      <version>1.0.0</version>
      <classifier>tests</classifier>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>se.fk.rimfrost</groupId>
      <artifactId>rimfrost-service-oul-asyncapi</artifactId>
      <version>1.0.0</version>
    </dependency>
    <dependency>
      <groupId>se.fk.rimfrost.framework.handlaggning</groupId>
      <artifactId>rimfrost-framework-handlaggning-adapter</artifactId>
      <version>1.0.1</version>
    </dependency>
    <dependency>
      <groupId>se.fk.rimfrost.framework.uppgiftstatusprovider</groupId>
      <artifactId>rimfrost-framework-uppgift-status-provider-interface</artifactId>
      <version>1.0.0</version>
    </dependency>
    <dependency>
      <groupId>se.fk.rimfrost.framework.uppgiftstatusprovider</groupId>
      <artifactId>rimfrost-framework-uppgift-status-provider</artifactId>
      <version>1.0.0</version>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.wiremock</groupId>
      <artifactId>wiremock</artifactId>
      <version>3.13.2</version>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>io.smallrye.reactive</groupId>
      <artifactId>smallrye-reactive-messaging-in-memory</artifactId>
      <scope>test</scope>
    </dependency>

    <dependency>
      <groupId>org.awaitility</groupId>
      <artifactId>awaitility</artifactId>
      <version>4.2.0</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <repositories>
    <repository>
      <id>central</id>
      <url>https://repo.maven.apache.org/maven2</url>
    </repository>
    <repository>
      <id>github--Forsakringskassan--repository</id>
      <url>https://maven.pkg.github.com/Forsakringskassan/repository</url>
    </repository>
  </repositories>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.15.0</version>
        <configuration>
          <compilerArgs>
            <arg>-parameters</arg>
          </compilerArgs>
          <annotationProcessorPaths>
            <path>
              <groupId>org.immutables</groupId>
              <artifactId>value-processor</artifactId>
              <version>2.10.0</version>
            </path>
          </annotationProcessorPaths>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-surefire-plugin</artifactId>
        <configuration>
          <excludes>
            <exclude>**/Abstract*.java</exclude>
          </excludes>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.4.2</version>
        <executions>
          <execution>
            <goals>
              <goal>test-jar</goal>
            </goals>
            <configuration>
              <includes>
                <include>**/base/</include>
                <include>**/helpers/</include>
              </includes>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
